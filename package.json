{
  "name": "qa-automation-platform",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "description": "Production-grade, self-healing QA automation platform for SaaS",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "setup": "pnpm install && npx playwright install --with-deps",
    "test:e2e": "npx playwright test",
    "clean": "npx rimraf **/node_modules **/dist **/.next",
    "docker:up": "pnpm -C packages/infra docker:up",
    "docker:down": "pnpm -C packages/infra docker:down"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "rimraf": "^5.0.5"
  }
}
