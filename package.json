{
  "name": "tu-proyecto",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "description": "Production-grade, self-healing QA automation platform for SaaS",
  "scripts": {
    "preinstall": "npx -y pnpm@9.12.3 --version",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "db:seed": "tsx scripts/populate-sample-data.ts",
    "setup": "pnpm install && npx playwright install --with-deps",
    "test:e2e": "npx playwright test",
    "clean": "npx rimraf **/node_modules **/dist **/.next",
    "docker:up": "pnpm -C packages/infra docker:up",
    "docker:down": "pnpm -C packages/infra docker:down"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "next": "14.x",
    "react": "18.x",
    "react-dom": "18.x"
  }
}