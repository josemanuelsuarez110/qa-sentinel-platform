{
  "name": "tu-proyecto",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "description": "Production-grade, self-healing QA automation platform for SaaS",
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "db:seed": "tsx scripts/populate-sample-data.ts",
    "setup": "npm install && npx playwright install --with-deps",
    "test:e2e": "npx playwright test",
    "clean": "npx rimraf **/node_modules **/dist **/.next",
    "docker:up": "npm run docker:up --workspace packages/infra --if-present",
    "docker:down": "npm run docker:down --workspace packages/infra --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "next": "14.x",
    "react": "18.x",
    "react-dom": "18.x"
  }
}
