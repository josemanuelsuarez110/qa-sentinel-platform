{
  "name": "tu-proyecto",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "description": "Production-grade, self-healing QA automation platform for SaaS",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "db:seed": "tsx scripts/populate-sample-data.ts",
    "setup": "pnpm install && npx playwright install --with-deps",
    "test:e2e": "npx playwright test",
    "clean": "npx rimraf **/node_modules **/dist **/.next",
    "docker:up": "pnpm --filter packages/infra exec npm run docker:up --if-present",
    "docker:down": "pnpm --filter packages/infra exec npm run docker:down --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "next": "14.x",
    "react": "18.x",
    "react-dom": "18.x"
  }
}
